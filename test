}
.page-title-bar { width: 100%; padding: 10px 32px; }
.page-title-text {
  font-family: "Unbounded", sans-serif; font-size: 13px; font-weight: 600;
  color: rgba(232,228,220,0.85); letter-spacing: 0.06em;
}
.page-title-text span {
  background: linear-gradient(135deg, #c9a84c, #f5d380);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.main {
  display: flex; width: 100%; max-width: 1400px;
  padding: 12px 24px 24px; gap: 20px; flex: 1;
}
.video-col { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 16px; }
.video-wrap {
  position: relative; padding-top: 56.25%; width: 100%;
  border-radius: 12px; overflow: hidden; background: #111;
  box-shadow: 0 8px 40px rgba(0,0,0,0.6);
}
.video-wrap iframe { position: absolute; top:0; left:0; width:100%; height:100%; border:0; }
.cta-btn {
  display: block; width: 100%; padding: 18px;
  background: linear-gradient(135deg, #e63946 0%, #c1121f 100%);
  color: #fff; text-align: center; text-decoration: none;
  font-family: "Unbounded", sans-serif; font-size: 15px; font-weight: 600;
  letter-spacing: 0.03em; border-radius: 10px;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 24px rgba(230,57,70,0.35);
}
.cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(230,57,70,0.5); }
.chat-col {
  width: 320px; flex-shrink: 0; display: flex; flex-direction: column;
  background: rgba(17,17,21,0.85); border: 1px solid #1e1e26;
  border-radius: 12px; overflow: hidden; max-height: 600px; min-height: 400px;
  backdrop-filter: blur(8px);
}
.chat-header {
  padding: 14px 16px; border-bottom: 1px solid #1e1e26; flex-shrink: 0;
  display: flex; align-items: center; justify-content: space-between;
}
.chat-header-title {
  font-family: "Unbounded", sans-serif; font-size: 11px; font-weight: 600;
  color: #666; letter-spacing: 0.1em; text-transform: uppercase;
}
.chat-sync-dot {
  width: 7px; height: 7px; border-radius: 50%; background: #333;
  transition: background 0.3s;
}
.chat-sync-dot.active { background: #51cf66; }
.chat-messages {
  flex: 1; overflow-y: auto; padding: 12px;
  display: flex; flex-direction: column; gap: 10px; scroll-behavior: smooth;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: #2a2a32; border-radius: 2px; }
.msg { display: flex; flex-direction: column; gap: 3px; animation: fadeInUp 0.3s ease forwards; opacity: 0; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
.msg-header { display: flex; align-items: center; gap: 6px; }
.msg-avatar {
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 600; flex-shrink: 0; color: #fff;
