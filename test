.msg-username { font-size: 12px; font-weight: 600; color: #aaa; }
.msg-username.host { color: #e63946; }
.msg-text {
  font-size: 13px; color: #d0ccc4; line-height: 1.5;
  padding-left: 28px; white-space: pre-wrap; word-break: break-word;
}
@media (max-width: 900px) {
  .main { flex-direction: column; padding: 12px; }
  .chat-col { width: 100%; height: 300px; min-height: 300px; }
  .header { padding: 14px 16px; }
  .page-title-bar { padding: 8px 16px; }
}
</style>
