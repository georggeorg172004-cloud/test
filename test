// Конвертируем из миллисекунд (timeshift) в секунды (time) для работы с плеером
const chatMessages = rawBizonData.data.map(item => ({
  time: item.timeshift / 1000, 
  username: item.username,
  message: item.message,
  role: item.role
}));

// Сортируем сообщения по времени на всякий случай
chatMessages.sort((a, b) => a.time - b.time);

const colors = [
  "#4a9eff","#ff6b6b","#51cf66","#ffd43b","#cc5de8",
  "#ff922b","#20c997","#f06595","#74c0fc","#a9e34b"
];
const userColors = {};
function getColor(name) {
  if (!userColors[name]) {
    userColors[name] = colors[Object.keys(userColors).length % colors.length];
  }
  return userColors[name];
}

const chatBox = document.getElementById("chatBox");
const syncDot = document.getElementById("syncDot");
const iframe = document.getElementById("kplayer");

let msgIndex = 0;
let playerReady = false;

function addMessage(msg) {
  const color = getColor(msg.username);
  const isHost = msg.role === "host" || msg.role === "moderator";
  const safeMsg = msg.message.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  const div = document.createElement("div");
  div.className = "msg";
  div.innerHTML =
    "<div class='msg-header'>" +
    "<div class='msg-avatar' style='background:" + color + "'></div>" +
    "<span class='msg-username " + (isHost ? "host" : "") + "'>" + msg.username + "</span>" +
    "</div>" +
    "<div class='msg-text'>" + safeMsg + "</div>";
  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

function syncChatToTime(currentTime) {
  if (msgIndex > 0 && chatMessages[msgIndex - 1].time > currentTime + 1) {
    chatBox.innerHTML = "";
    msgIndex = 0;
  }
  while (msgIndex < chatMessages.length && chatMessages[msgIndex].time <= currentTime) {
    addMessage(chatMessages[msgIndex]);
    msgIndex++;
  }
}

function sendToPlayer(method, args) {
  iframe.contentWindow.postMessage({
    context: "player.js",
    method: method,
    args: args || []
  }, "https://kinescope.io");
}

window.addEventListener("message", function(e) {
  if (e.origin !== "https://kinescope.io") return;
  var data = e.data;
  if (!data || !data.event) return;

  if (data.event === "ready") {
    playerReady = true;
    syncDot.classList.add("active");
    // Подписываемся на timeupdate, play, pause, seeked
    sendToPlayer("addEventListener", ["timeupdate"]);
    sendToPlayer("addEventListener", ["play"]);
    sendToPlayer("addEventListener", ["pause"]);
    sendToPlayer("addEventListener", ["seeked"]);
  }

  if (data.event === "timeupdate" && data.value && typeof data.value.currentTime === "number") {
    syncChatToTime(data.value.currentTime);
  }

  if (data.event === "seeked" && data.value && typeof data.value.currentTime === "number") {
    syncChatToTime(data.value.currentTime);
  }
});
</script>
